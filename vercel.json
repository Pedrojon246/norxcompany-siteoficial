{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/produtos/norxcoin", "destination": "/produtos/norxcoin.html" },
    { "source": "/produtos/norxpay", "destination": "/produtos/norxpay.html" },
    { "source": "/produtos/grupbuy", "destination": "/produtos/grupbuy.html" },
    { "source": "/produtos/corretor-pro", "destination": "/produtos/corretor-pro.html" },
    { "source": "/produtos/snake-mining", "destination": "/produtos/snake-mining.html" },
    { "source": "/blog", "destination": "/blog/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
